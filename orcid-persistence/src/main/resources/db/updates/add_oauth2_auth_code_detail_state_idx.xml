<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.3.xsd">

    <changeSet id="ADD-OAUTH2-AUTH-CODE-DETAIL-STATE-IDX"
               author="gwestwood"
               dbms="postgresql"
               runInTransaction="false">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="oauth2_authoriziation_code_detail_state_idx"
                             tableName="oauth2_authoriziation_code_detail" />
            </not>
        </preConditions>
        <sql>
            CREATE INDEX CONCURRENTLY oauth2_authoriziation_code_detail_state_idx
              ON oauth2_authoriziation_code_detail
                 (authorization_state_attribute);
        </sql>
        <rollback>
            <sql>DROP INDEX CONCURRENTLY IF EXISTS oauth2_authoriziation_code_detail_state_idx;</sql>
        </rollback>
    </changeSet>

</databaseChangeLog>

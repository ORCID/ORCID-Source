<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-2.0.xsd">

    <changeSet id="INCREASE-ATTRIBUTES-LENGHT" author="Angel Montenegro" dbms="postgresql">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="oauth2_authoriziation_code_detail" columnName="attributes"/>
            </not>
        </preConditions>
        <sql>ALTER TABLE oauth2_authoriziation_code_detail ALTER COLUMN attributes TYPE VARCHAR(8000)</sql>
    </changeSet>
</databaseChangeLog>